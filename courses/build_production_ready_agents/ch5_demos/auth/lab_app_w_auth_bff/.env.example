APP_NAME="adk_agent_app"
GOOGLE_CLOUD_PROJECT=""
SESSION_SERVICE_PROVIDER="in_memory"

# --- BFF OAuth configuration ---
# Unlike the Bearer-token variant, the BFF server does the OAuth exchange itself,
# so it needs BOTH the client id AND the client secret.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
# Must be registered as an Authorized redirect URI on the OAuth client.
OAUTH_REDIRECT_URI="http://localhost:8080/auth/callback"
# Where the browser is sent after a successful login. The client UI is served at
# "/" by this same server, so this is just the app root.
CLIENT_APP_URL="http://localhost:8080/"
# CORS origin. Not load-bearing now that the UI and API are same-origin, but kept
# aligned with the server's own origin.
CLIENT_ORIGIN="http://localhost:8080"

GOOGLE_GENAI_USE_VERTEXAI=TRUE
