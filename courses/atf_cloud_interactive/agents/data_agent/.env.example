OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=True
MODEL_ARMOR_LOCATION=us
MODEL_ARMOR_TEMPLATE=projects/<YOUR_PROJECT_ID>/locations/us/templates/mask_emails